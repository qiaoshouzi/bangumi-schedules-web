---
import Footer from '@/components/Footer.astro'

interface Props {
  lang?: string
  title?: string
}
const { lang = 'en', title } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="initial-scale=1,maximum-scale=1, minimum-scale=1, user-scalable=no, width=device-width"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{`Bangumi Schedules${title ? ` - ${title}` : ''}`}</title>

    <style is:global>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
      }

      html {
        scroll-behavior: smooth;
      }

      a {
        color: #007aff; /* 经典的品牌蓝 */
        text-decoration: none; /* 去掉默认下划线 */
        transition: color 0.2s ease; /* 让颜色变化更丝滑 */
      }

      a:hover {
        color: #0056b3; /* 悬停时加深颜色 */
        text-decoration: underline; /* 仅在悬停时显示下划线 */
      }
    </style>

    <style is:global>
      :root {
        --bg: #fff;
        --text: #000;
        --table-header-bg: rgb(228 240 245);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1a1a1a;
          --text: #f5f5f5;
          --table-header-bg: rgb(27, 38, 44);
        }
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        transition: background-color 0.3s;
      }
    </style>

    <script>
      if ('serviceWorker' in navigator)
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js', { type: 'module', scope: '/' })
            .then(() => console.log('Service worker registered successfully.'))
            .catch((e) => console.error('Service worker registration failed:', e))
        })
    </script>
  </head>
  <body>
    <slot />

    <Footer />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/flag-icons@7.5.0/css/flag-icons.min.css"
      integrity="sha256-tyPeBlnZW2qWbAF1hQiCt9qo6SOgOSymvJBum+FrrwI="
      crossorigin="anonymous"
      blocking="render"
      media="print"
    />
  </body>
</html>
